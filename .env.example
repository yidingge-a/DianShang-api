# 应用
APP_NAME=全链路电商智能系统
APP_ENV=dev
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# 数据库（开发 SQLite；生产 PostgreSQL + Alembic）
DATABASE_URL=sqlite:///./data/ecommerce.db
# DATABASE_URL=postgresql+psycopg2://dianshang:强密码@localhost:5432/ecommerce

# JWT（生产务必更换 SECRET_KEY，DEBUG=false）
SECRET_KEY=请替换为随机长字符串
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# 文件上传
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE=10485760
MAX_VIDEO_SIZE=104857600
BASE_URL=http://localhost:8000

# CORS（前端开发地址 8080，逗号分隔；生产填正式域名）
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Redis / Celery（生产建议开启）
REDIS_URL=redis://localhost:6379/0
CELERY_ENABLED=false

# 对象存储（local | s3）
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

# 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_LLM=30/minute

# ===============================
# LLM（与 deploy/.env 同名；运行 scripts/sync_env_from_deploy.sh 可自动同步）
# ===============================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://kuaipao.ai/v1
LLM_CHAT_MODEL=gpt-5.4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=120

# ===============================
# 视觉（BOM 识图 / 抠图）：OpenAI 兼容多模态
# 本地 vLLM 示例:
#   VISION_API_BASE=http://127.0.0.1:8001/v1
#   VISION_MODEL=qwen2-vl-7b-instruct
# 阿里云 DashScope 千问 VL 示例:
#   VISION_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
#   VISION_API_KEY=与 DASHSCOPE_API_KEY 相同
#   VISION_MODEL=qwen-vl-plus
# ===============================
VISION_API_BASE=
VISION_API_KEY=
VISION_MODEL=
VISION_TIMEOUT_SECONDS=180

# ===============================
# 阿里云 DashScope 万相出图（文生图 / 图编辑）
# ===============================
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_IMAGE_MODEL=wan2.7-image-pro

# ===============================
# 视频 API（未配置且有 ffmpeg 时自动合成幻灯片 mp4）
# ===============================
VIDEO_API_BASE=
VIDEO_API_KEY=
VIDEO_MODEL=

# ===============================
# 电商数据 API（比价/市场/监控第三方服务）
# ===============================
ECOMMERCE_DATA_API_BASE=
ECOMMERCE_DATA_API_KEY=

# ===============================
# 平台上架（发布网关或各平台 OpenAPI）
# ===============================
PUBLISH_GATEWAY_URL=
PUBLISH_GATEWAY_API_KEY=
TAOBAO_OPEN_API_KEY=
TAOBAO_OPEN_API_SECRET=
JD_OPEN_API_KEY=
PDD_OPEN_API_KEY=
